# UOFast MCP Server — Environment Variables
# Copy to .env and fill in real values (never commit .env to git)

# ============================================================
# REQUIRED — Security
# ============================================================

# Application secret key — used for session encryption and credential storage (not JWT tokens)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING

# Initial admin password (used once on first startup to seed the admin user)
INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================
# OPTIONAL — Database
# ============================================================

# SQLite (default, file in ./data/security.db)
# DATABASE_URL=sqlite+aiosqlite:///./data/security.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://uofast:password@db:5432/uofast_security

# ============================================================
# OPTIONAL — U2 UniData connection
# ============================================================

UNIDATA_HOST=your-unidata-host
UNIDATA_PORT=31438
UNIDATA_USERNAME=your-username
UNIDATA_PASSWORD=your-password
UNIDATA_ACCOUNT=C:\U2\UD83\DEMO
UNIDATA_SERVICE=udcs

# ============================================================
# OPTIONAL — U2 UniData connection pool
# ============================================================

# Minimum number of named connections to keep active (0 = no minimum, warn at startup if below)
# UNIDATA_MIN_CONNECTIONS=1

# Maximum number of named connections allowed (0 = unlimited)
# UNIDATA_MAX_CONNECTIONS=10

# ============================================================
# OPTIONAL — Azure AD (future phase, currently stubbed)
# ============================================================

# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=

# ============================================================
# OPTIONAL — App settings
# ============================================================

# ENABLE_DOCS=true   # Set to false to disable /docs in production
